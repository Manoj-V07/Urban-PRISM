{
  "appId": "com.urbanprism.app",
  "appName": "Urban PRISM",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#f8fafc",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "Keyboard": {
      "resize": "body"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#f8fafc"
    }
  }
}
